   "source": [
    "### Insertion sort"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5175513f",
   "metadata": {},
   "outputs": [],
   "source": [
    "def Insertion_sort(nums):\n",
    "    n=len(nums)\n",
    "    for i in range(1,n):\n",
    "        key=nums[i]\n",
    "        j=i-1\n",
    "        while j>=0 and nums[j]>key:\n",
    "            nums[j+1]=nums[j]\n",
    "            j-=1\n",
    "        nums[j+1]=key\n",
    "    return nums\n",
    "nums=[7,6,1,4]\n",
    "print(Insertion_sort(nums))\n"
   ]
  }
 ],
