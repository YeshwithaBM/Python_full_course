    "### Problem 1: Reverse Array"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 34,
   "id": "0cadccde",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[50, 30, 20, 80]\n"
     ]
    }
   ],
   "source": [
    "def reverse_array(nums):\n",
    "    left=0\n",
    "    right = len(nums) - 1\n",
    "    while left < right:\n",
    "         nums[left], nums[right] = nums[right], nums[left]\n",
    "         left+=1\n",
    "         right-=1\n",
    "    return nums\n",
    "nums=[80,20,30,50]\n",
    "print(reverse_array(nums))"
   ]
  }
 ],
